{
  "name": "GenAI101",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    }
  },
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "GenAI101 web app",
      "onAutoForward": "openBrowser"
    }
  },
  "postCreateCommand": "python3 -m pip install --upgrade pip && echo 'Devcontainer ready. Run: python3 -m http.server 8000  then open http://localhost:8000'",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "esbenp.prettier-vscode",
        "yzhang.markdown-all-in-one"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "remoteUser": "vscode"
}
